<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Serbian QWERTZ row 3: y·x  c·v  b·n  m·đ  (4 pairs × 17.75%)
     ž (U+017E) moved UP to row 2. đ (U+0111) pairs with m. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="y"
        latin:keySecondarySpec="x"
        latin:moreKeys="!text/morekeys_y" />
    <Key latin:keySpec="c"
        latin:keySecondarySpec="v"
        latin:moreKeys="!text/morekeys_c,!text/morekeys_v" />
    <Key latin:keySpec="b"
        latin:keySecondarySpec="n"
        latin:moreKeys="!text/morekeys_n" />
    <!-- U+0111: "đ" LATIN SMALL LETTER D WITH STROKE -->
    <Key latin:keySpec="m"
        latin:keySecondarySpec="&#x0111;" />
</merge>
