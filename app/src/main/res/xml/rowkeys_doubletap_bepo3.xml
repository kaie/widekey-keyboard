<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Bépo row 3: y·x  k·-  q·g  h·f  (4 pairs × 17.75%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="y"
        latin:keySecondarySpec="x"
        latin:moreKeys="!text/morekeys_y"
        latin:keyHintLabel="&quot;"
        latin:keyHintLabelLeft="*"
        latin:additionalMoreKeys="*,&quot;" />
    <Key latin:keySpec="k"
        latin:keySecondarySpec="-"
        latin:moreKeys="!text/morekeys_k,_,&#x2013;,&#x2014;"
        latin:keyHintLabelLeft="'"
        latin:additionalMoreKeys="'" />
    <Key latin:keySpec="q"
        latin:keySecondarySpec="g"
        latin:moreKeys="!text/morekeys_g"
        latin:keyHintLabel=";"
        latin:keyHintLabelLeft=":"
        latin:additionalMoreKeys=":,;" />
    <Key latin:keySpec="h"
        latin:keySecondarySpec="f"
        latin:moreKeys="!text/morekeys_h" />
</merge>
