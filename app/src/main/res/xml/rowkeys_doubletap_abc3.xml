<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap ABC row 3: u·v  w·x  y·z  (3 pairs × 23.667%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- u·v: left="(u) right='(v) -->
    <Key latin:keySpec="u" latin:keySecondarySpec="v" latin:moreKeys="!text/morekeys_u,!text/morekeys_v"
        latin:keyHintLabel="'"
        latin:keyHintLabelLeft="&quot;"
        latin:additionalMoreKeys="&quot;,'" />
    <!-- w·x: left=:(w) right=;(x) -->
    <Key latin:keySpec="w" latin:keySecondarySpec="x" latin:moreKeys="!text/morekeys_w,!text/morekeys_x"
        latin:keyHintLabel=";"
        latin:keyHintLabelLeft=":"
        latin:additionalMoreKeys=":,;" />
    <!-- y·z: left=!(y) right=?(z) — 3-pair row, no right-edge swap -->
    <Key latin:keySpec="y" latin:keySecondarySpec="z" latin:moreKeys="!text/morekeys_y,!text/morekeys_z"
        latin:keyHintLabel="\?"
        latin:keyHintLabelLeft="!"
        latin:additionalMoreKeys="!,\?" />
</merge>
