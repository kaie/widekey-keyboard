<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Colemak row 2: a·r  s·t  d·h  n·e  i·o  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="a" latin:keySecondarySpec="r" latin:moreKeys="!text/morekeys_a,!text/morekeys_r"
        latin:keyHintLabel="#"
        latin:keyHintLabelLeft="\@"
        latin:additionalMoreKeys="\@,#" />
    <Key latin:keySpec="s" latin:keySecondarySpec="t" latin:moreKeys="!text/morekeys_s,!text/morekeys_t"
        latin:keyHintLabel="%"
        latin:keyHintLabelLeft="$"
        latin:additionalMoreKeys="$,%" />
    <Key latin:keySpec="d" latin:keySecondarySpec="h" latin:moreKeys="!text/morekeys_d,!text/morekeys_h"
        latin:keyHintLabel="-"
        latin:keyHintLabelLeft="&amp;"
        latin:additionalMoreKeys="&amp;,-" />
    <Key latin:keySpec="n" latin:keySecondarySpec="e" latin:moreKeys="!text/morekeys_n,!text/morekeys_e"
        latin:keyHintLabel="("
        latin:keyHintLabelLeft="+"
        latin:additionalMoreKeys="+,(" />
    <Key latin:keySpec="i" latin:keySecondarySpec="o" latin:moreKeys="!text/morekeys_i,!text/morekeys_o"
        latin:keyHintLabel="/"
        latin:keyHintLabelLeft=")"
        latin:additionalMoreKeys="/,)" />
</merge>
