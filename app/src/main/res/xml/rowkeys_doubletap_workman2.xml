<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Workman row 2: a·s  h·t  g·y  n·e  o·i  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="a" latin:keySecondarySpec="s" latin:moreKeys="!text/morekeys_a,!text/morekeys_r"
        latin:keyHintLabel="#"
        latin:keyHintLabelLeft="\@"
        latin:additionalMoreKeys="\@,#" />
    <Key latin:keySpec="h" latin:keySecondarySpec="t" latin:moreKeys="!text/morekeys_s,!text/morekeys_t"
        latin:keyHintLabel="%"
        latin:keyHintLabelLeft="$"
        latin:additionalMoreKeys="$,%" />
    <Key latin:keySpec="g" latin:keySecondarySpec="y" latin:moreKeys="!text/morekeys_d,!text/morekeys_h"
        latin:keyHintLabel="-"
        latin:keyHintLabelLeft="&amp;"
        latin:additionalMoreKeys="&amp;,-" />
    <Key latin:keySpec="n" latin:keySecondarySpec="e" latin:moreKeys="!text/morekeys_n,!text/morekeys_e"
        latin:keyHintLabel="("
        latin:keyHintLabelLeft="+"
        latin:additionalMoreKeys="+,(" />
    <Key latin:keySpec="o" latin:keySecondarySpec="i" latin:moreKeys="!text/morekeys_i,!text/morekeys_o"
        latin:keyHintLabel="/"
        latin:keyHintLabelLeft=")"
        latin:additionalMoreKeys="/,)" />
</merge>
