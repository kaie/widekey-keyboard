<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap HCesar row 2: q·t  d·i  n·u  l·m  x·.  (5 pairs × 20%)
     The conditional »/. key is simplified to period secondary with » in moreKeys. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="q"
        latin:keySecondarySpec="t" />
    <Key latin:keySpec="d"
        latin:keySecondarySpec="i"
        latin:moreKeys="!text/morekeys_i" />
    <Key latin:keySpec="n"
        latin:keySecondarySpec="u"
        latin:moreKeys="!text/morekeys_u" />
    <Key latin:keySpec="l"
        latin:keySecondarySpec="m" />
    <!-- U+00BB: "»" RIGHT-POINTING DOUBLE ANGLE QUOTATION MARK in moreKeys -->
    <Key latin:keySpec="x"
        latin:keySecondarySpec="."
        latin:moreKeys="&#x00BB;,\\?" />
</merge>
