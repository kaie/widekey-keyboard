<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Hebrew row 1: 5 pairs × 20%
     Pairs (left·right): '·-  ק·ר  א·ט  ו·ן  ם·פ
     RTL tap convention: single tap = right char, double tap = left char -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- '·- -->
    <Key
        latin:keySpec="\'"
        latin:keySecondarySpec="-" />
    <!-- ק·ר -->
    <Key
        latin:keySpec="&#x05E7;"
        latin:keySecondarySpec="&#x05E8;" />
    <!-- א·ט -->
    <Key
        latin:keySpec="&#x05D0;"
        latin:keySecondarySpec="&#x05D8;" />
    <!-- ו·ן -->
    <Key
        latin:keySpec="&#x05D5;"
        latin:keySecondarySpec="&#x05DF;" />
    <!-- ם·פ -->
    <Key
        latin:keySpec="&#x05DD;"
        latin:keySecondarySpec="&#x05E4;" />
</merge>
