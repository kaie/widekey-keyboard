<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Hindi Compact layout rows.
     Row 1: 5 pairs + 1 solo @ 16.667% = 100%
     Row 2: 5 pairs + 1 solo @ 16.667% = 100%
     Row 3: 5 pairs @ 18.182% + delete(fillRight) = 100%
     Row 4: doubletap spacebar row -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row
        latin:keyWidth="16.667%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_hindi_compact1" />
    </Row>
    <Row
        latin:keyWidth="16.667%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_hindi_compact2" />
    </Row>
    <Row
        latin:keyWidth="18.182%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_hindi_compact3" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyWidth="fillRight" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_qwerty4" />
</merge>
