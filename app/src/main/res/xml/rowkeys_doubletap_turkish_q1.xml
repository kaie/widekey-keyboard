<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Turkish Q row 1: q·w  e·r  t·y  u·ı  o·p  ğ·ü  (6 pairs × 16.667%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <Key latin:keySpec="q"
                latin:keySecondarySpec="w"
                latin:moreKeys="!text/morekeys_w"
                latin:keyHintLabel="\\"
                latin:keyHintLabelLeft="_"
                latin:additionalMoreKeys="_,\\" />
            <Key latin:keySpec="e"
                latin:keySecondarySpec="r"
                latin:moreKeys="!text/morekeys_e,!text/morekeys_r"
                latin:keyHintLabel="="
                latin:keyHintLabelLeft="|"
                latin:additionalMoreKeys="\|,=" />
            <Key latin:keySpec="t"
                latin:keySecondarySpec="y"
                latin:moreKeys="!text/morekeys_t,!text/morekeys_y"
                latin:keyHintLabel="]"
                latin:keyHintLabelLeft="["
                latin:additionalMoreKeys="[,]" />
            <!-- ı: U+0131 LATIN SMALL LETTER DOTLESS I -->
            <Key latin:keySpec="u"
                latin:keySecondarySpec="ı"
                latin:moreKeys="!text/morekeys_u,!text/morekeys_i"
                latin:keyHintLabel="&gt;"
                latin:keyHintLabelLeft="&lt;"
                latin:additionalMoreKeys="&lt;,&gt;" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_o"
                latin:keyHintLabel="}"
                latin:keyHintLabelLeft="{"
                latin:additionalMoreKeys="{,}" />
            <!-- ğ: LATIN SMALL LETTER G WITH BREVE  ü: LATIN SMALL LETTER U WITH DIAERESIS -->
            <Key latin:keySpec="ğ"
                latin:keySecondarySpec="ü"
                latin:keyHintLabel="~"
                latin:keyHintLabelLeft="°"
                latin:additionalMoreKeys="~,°" />
        </case>
        <default>
            <Key latin:keySpec="q"
                latin:keySecondarySpec="w"
                latin:moreKeys="!text/morekeys_w"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="e"
                latin:keySecondarySpec="r"
                latin:moreKeys="!text/morekeys_e,!text/morekeys_r"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="t"
                latin:keySecondarySpec="y"
                latin:moreKeys="!text/morekeys_t,!text/morekeys_y"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <!-- ı: U+0131 LATIN SMALL LETTER DOTLESS I -->
            <Key latin:keySpec="u"
                latin:keySecondarySpec="ı"
                latin:moreKeys="!text/morekeys_u,!text/morekeys_i"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_o"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="9,0" />
            <!-- ğ·ü: no digit assignment (beyond 10 digits); keep bracket hints -->
            <Key latin:keySpec="ğ"
                latin:keySecondarySpec="ü"
                latin:keyHintLabel="~"
                latin:keyHintLabelLeft="°"
                latin:additionalMoreKeys="~,°" />
        </default>
    </switch>
</merge>
