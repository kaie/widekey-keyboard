<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Greek row 1: ;·ς  ε·ρ  τ·υ  θ·ι  ο·π  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <!-- ;·ς: left=_(;) right=\(ς) -->
            <Key latin:keySpec="&#x003B;" latin:keySecondarySpec="&#x03C2;"
                latin:keyHintLabel="\\"
                latin:keyHintLabelLeft="_"
                latin:additionalMoreKeys="_,\\" />
            <!-- ε·ρ: left=|(ε) right==(ρ) -->
            <Key latin:keySpec="&#x03B5;" latin:keySecondarySpec="&#x03C1;" latin:moreKeys="&#x03AD;"
                latin:keyHintLabel="="
                latin:keyHintLabelLeft="|"
                latin:additionalMoreKeys="\|,=" />
            <!-- τ·υ: left=[(τ) right=](υ) -->
            <Key latin:keySpec="&#x03C4;" latin:keySecondarySpec="&#x03C5;" latin:moreKeys="&#x03CD;,&#x03CB;,&#x03B0;"
                latin:keyHintLabel="]"
                latin:keyHintLabelLeft="["
                latin:additionalMoreKeys="[,]" />
            <!-- θ·ι: left=<(θ) right=>(ι) -->
            <Key latin:keySpec="&#x03B8;" latin:keySecondarySpec="&#x03B9;" latin:moreKeys="&#x03AF;,&#x03CA;,&#x0390;"
                latin:keyHintLabel="&gt;"
                latin:keyHintLabelLeft="&lt;"
                latin:additionalMoreKeys="&lt;,&gt;" />
            <!-- ο·π: left={(ο) right=}(π) — right-edge: additionalMoreKeys right-first -->
            <Key latin:keySpec="&#x03BF;" latin:keySecondarySpec="&#x03C0;" latin:moreKeys="&#x03CC;"
                latin:keyHintLabel="}"
                latin:keyHintLabelLeft="{"
                latin:additionalMoreKeys="},{" />
        </case>
        <default>
            <Key latin:keySpec="&#x003B;" latin:keySecondarySpec="&#x03C2;"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="&#x03B5;" latin:keySecondarySpec="&#x03C1;" latin:moreKeys="&#x03AD;"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="&#x03C4;" latin:keySecondarySpec="&#x03C5;" latin:moreKeys="&#x03CD;,&#x03CB;,&#x03B0;"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="&#x03B8;" latin:keySecondarySpec="&#x03B9;" latin:moreKeys="&#x03AF;,&#x03CA;,&#x0390;"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="&#x03BF;" latin:keySecondarySpec="&#x03C0;" latin:moreKeys="&#x03CC;"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="0,9" />
        </default>
    </switch>
</merge>
