<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Serbian QWERTZ layout rows.
     Row 1: 5 pairs + 1 solo(š) × 16.667% = 100%
     Row 2: 6 pairs × 16.667% = 100% (ž moved up from row 3)
     Row 3: shift(14%) + 4 pairs × 17.75% + delete(14%) ≈ 100%
     Row 4: doubletap spacebar row -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row latin:keyWidth="16.667%p">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_serbian_qwertz1" />
    </Row>
    <Row latin:keyWidth="16.667%p">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_serbian_qwertz2" />
    </Row>
    <Row latin:keyWidth="17.75%p">
        <Key
            latin:keyStyle="shiftKeyStyle"
            latin:keyWidth="14%p" />
        <include
            latin:keyXPos="15%p"
            latin:keyboardLayout="@xml/rowkeys_doubletap_serbian_qwertz3" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyXPos="86%p"
            latin:keyWidth="14%p" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_qwerty4" />
</merge>
