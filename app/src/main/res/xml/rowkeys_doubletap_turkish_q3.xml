<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Turkish Q row 3: z·x  c·v  b·n  m·ö  (4 pairs × 17.75%)
     ç moved UP to row 2. ö pairs with m. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="z"
        latin:keySecondarySpec="x"
        latin:moreKeys="!text/morekeys_z,!text/morekeys_x" />
    <Key latin:keySpec="c"
        latin:keySecondarySpec="v"
        latin:moreKeys="!text/morekeys_c,!text/morekeys_v" />
    <Key latin:keySpec="b"
        latin:keySecondarySpec="n"
        latin:moreKeys="!text/morekeys_n" />
    <!-- ö: LATIN SMALL LETTER O WITH DIAERESIS -->
    <Key latin:keySpec="m"
        latin:keySecondarySpec="ö"
        latin:moreKeys="!text/morekeys_o" />
</merge>
