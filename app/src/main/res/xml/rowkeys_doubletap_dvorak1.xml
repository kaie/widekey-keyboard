<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Dvorak row 1: '·,  .·p  y·f  g·c  r·l  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <Key latin:keySpec="\'" latin:keySecondarySpec="\," />
            <Key latin:keySpec="." latin:keySecondarySpec="p"
                latin:keyHintLabel="="
                latin:additionalMoreKeys="=" />
            <Key latin:keySpec="y" latin:keySecondarySpec="f" latin:moreKeys="!text/morekeys_y"
                latin:keyHintLabel="]"
                latin:keyHintLabelLeft="["
                latin:additionalMoreKeys="[,]" />
            <Key latin:keySpec="g" latin:keySecondarySpec="c" latin:moreKeys="!text/morekeys_g,!text/morekeys_c"
                latin:keyHintLabel="&gt;"
                latin:keyHintLabelLeft="&lt;"
                latin:additionalMoreKeys="&lt;,&gt;" />
            <Key latin:keySpec="r" latin:keySecondarySpec="l" latin:moreKeys="!text/morekeys_r,!text/morekeys_l"
                latin:keyHintLabel="}"
                latin:keyHintLabelLeft="{"
                latin:additionalMoreKeys="},{" />
        </case>
        <default>
            <Key latin:keySpec="\'" latin:keySecondarySpec="\,"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="." latin:keySecondarySpec="p"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="y" latin:keySecondarySpec="f" latin:moreKeys="!text/morekeys_y"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="g" latin:keySecondarySpec="c" latin:moreKeys="!text/morekeys_g,!text/morekeys_c"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="r" latin:keySecondarySpec="l" latin:moreKeys="!text/morekeys_r,!text/morekeys_l"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="0,9" />
        </default>
    </switch>
</merge>
