<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Swiss row 1: q·w  e·r  t·z  u·i  o·p  [solo:swiss11]  (5 pairs + 1 solo × 16.667%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <Key latin:keySpec="q"
                latin:keySecondarySpec="w"
                latin:moreKeys="!text/morekeys_w" />
            <Key latin:keySpec="e"
                latin:keySecondarySpec="r"
                latin:moreKeys="!text/morekeys_e,!text/morekeys_r" />
            <Key latin:keySpec="t"
                latin:keySecondarySpec="z"
                latin:moreKeys="!text/morekeys_t,!text/morekeys_z" />
            <Key latin:keySpec="u"
                latin:keySecondarySpec="i"
                latin:moreKeys="!text/morekeys_u,!text/morekeys_i" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_o" />
        </case>
        <default>
            <Key latin:keySpec="q"
                latin:keySecondarySpec="w"
                latin:moreKeys="!text/morekeys_w"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="e"
                latin:keySecondarySpec="r"
                latin:moreKeys="!text/morekeys_e,!text/morekeys_r"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="t"
                latin:keySecondarySpec="z"
                latin:moreKeys="!text/morekeys_t,!text/morekeys_z"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="u"
                latin:keySecondarySpec="i"
                latin:moreKeys="!text/morekeys_u,!text/morekeys_i"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_o"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="9,0" />
        </default>
    </switch>
    <!-- Solo key: locale-specific 11th key (é, è, ö, etc.) -->
    <Key latin:keySpec="!text/keyspec_swiss_row1_11"
        latin:moreKeys="!text/morekeys_swiss_row1_11" />
</merge>
