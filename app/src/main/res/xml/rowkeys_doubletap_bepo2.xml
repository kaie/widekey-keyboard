<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Bépo row 2: a·u  i·e  c·t  s·r  n·m  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="a"
        latin:keySecondarySpec="u"
        latin:moreKeys="!text/morekeys_a,!text/morekeys_u"
        latin:keyHintLabel="#"
        latin:keyHintLabelLeft="\@"
        latin:additionalMoreKeys="\@,#" />
    <Key latin:keySpec="i"
        latin:keySecondarySpec="e"
        latin:moreKeys="!text/morekeys_i,!text/morekeys_e"
        latin:keyHintLabel="%"
        latin:keyHintLabelLeft="€"
        latin:additionalMoreKeys="€,%" />
    <Key latin:keySpec="c"
        latin:keySecondarySpec="t"
        latin:moreKeys="!text/morekeys_c,!text/morekeys_t"
        latin:keyHintLabel="-"
        latin:keyHintLabelLeft="&amp;"
        latin:additionalMoreKeys="&amp;,-" />
    <Key latin:keySpec="s"
        latin:keySecondarySpec="r"
        latin:moreKeys="!text/morekeys_s,!text/morekeys_r"
        latin:keyHintLabel="("
        latin:keyHintLabelLeft="+"
        latin:additionalMoreKeys="+,(" />
    <Key latin:keySpec="n"
        latin:keySecondarySpec="m"
        latin:moreKeys="!text/morekeys_n"
        latin:keyHintLabel="/"
        latin:keyHintLabelLeft=")"
        latin:additionalMoreKeys="/,)" />
</merge>
