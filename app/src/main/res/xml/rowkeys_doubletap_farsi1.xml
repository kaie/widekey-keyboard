<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Farsi row 1: 5 pairs + 1 solo × 16.667%
     Pairs (left·right): ض·ص  ث·ق  ف·غ  ع·ه  خ·ح  solo: ج -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <!-- ض·ص -->
            <Key
                latin:keySpec="&#x0636;"
                latin:keySecondarySpec="&#x0635;" />
            <!-- ث·ق -->
            <Key
                latin:keySpec="&#x062B;"
                latin:keySecondarySpec="&#x0642;" />
            <!-- ف·غ -->
            <Key
                latin:keySpec="&#x0641;"
                latin:keySecondarySpec="&#x063A;" />
            <!-- ع·ه -->
            <Key
                latin:keySpec="&#x0639;"
                latin:keySecondarySpec="&#x0647;"
                latin:moreKeys="&#xFEEB;|&#x0647;&#x200D;,&#x0647;&#x0654;,&#x0629;,%" />
            <!-- خ·ح -->
            <Key
                latin:keySpec="&#x062E;"
                latin:keySecondarySpec="&#x062D;" />
        </case>
        <default>
            <!-- ض·ص: Farsi ۱·۲ (Extended Arabic-Indic) + Western 1·2 -->
            <Key
                latin:keySpec="&#x0636;"
                latin:keySecondarySpec="&#x0635;"
                latin:keyHintLabelLeft="&#x06F1;"
                latin:keyHintLabel="&#x06F2;"
                latin:additionalMoreKeys="&#x06F1;,1,&#x06F2;,2" />
            <!-- ث·ق: Farsi ۳·۴ + Western 3·4 -->
            <Key
                latin:keySpec="&#x062B;"
                latin:keySecondarySpec="&#x0642;"
                latin:keyHintLabelLeft="&#x06F3;"
                latin:keyHintLabel="&#x06F4;"
                latin:additionalMoreKeys="&#x06F3;,3,&#x06F4;,4" />
            <!-- ف·غ: Farsi ۵·۶ + Western 5·6 -->
            <Key
                latin:keySpec="&#x0641;"
                latin:keySecondarySpec="&#x063A;"
                latin:keyHintLabelLeft="&#x06F5;"
                latin:keyHintLabel="&#x06F6;"
                latin:additionalMoreKeys="&#x06F5;,5,&#x06F6;,6" />
            <!-- ع·ه: Farsi ۷·۸ + Western 7·8 -->
            <Key
                latin:keySpec="&#x0639;"
                latin:keySecondarySpec="&#x0647;"
                latin:moreKeys="&#xFEEB;|&#x0647;&#x200D;,&#x0647;&#x0654;,&#x0629;,%"
                latin:keyHintLabelLeft="&#x06F7;"
                latin:keyHintLabel="&#x06F8;"
                latin:additionalMoreKeys="&#x06F7;,7,&#x06F8;,8" />
            <!-- خ·ح: Farsi ۹·۰ + Western 9·0 (solo follows, so left-first) -->
            <Key
                latin:keySpec="&#x062E;"
                latin:keySecondarySpec="&#x062D;"
                latin:keyHintLabelLeft="&#x06F9;"
                latin:keyHintLabel="&#x06F0;"
                latin:additionalMoreKeys="&#x06F9;,9,&#x06F0;,0" />
        </default>
    </switch>
    <!-- ج solo -->
    <Key latin:keySpec="&#x062C;" />
</merge>
