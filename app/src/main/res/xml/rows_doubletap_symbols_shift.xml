<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap shifted symbols layout rows.
     Row 1: 5 pairs × 20% = 100%
     Row 2: 5 pairs × 20% = 100%
     Row 3: backFromMoreSymbol(14%) + 3 pairs × 23.667% + delete(14%) ≈ 100%
     Row 4: doubletap spacebar row -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <include latin:keyboardLayout="@xml/key_styles_common" />
    <include latin:keyboardLayout="@xml/key_styles_currency" />
    <Row latin:keyWidth="20%p">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_symbols_shift1" />
    </Row>
    <Row latin:keyWidth="20%p">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_symbols_shift2" />
    </Row>
    <Row latin:keyWidth="23.667%p">
        <Key
            latin:keyStyle="backFromMoreSymbolKeyStyle"
            latin:keyWidth="14%p" />
        <include
            latin:keyXPos="15%p"
            latin:keyboardLayout="@xml/rowkeys_doubletap_symbols_shift3" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyXPos="86%p"
            latin:keyWidth="14%p" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_symbols4" />
</merge>
