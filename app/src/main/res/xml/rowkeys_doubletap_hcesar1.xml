<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap HCesar row 1: h·c  e·s  a·r  o·p  z·,  (5 pairs × 20%)
     The conditional «/, key is simplified to comma secondary with « in moreKeys. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <Key latin:keySpec="h"
                latin:keySecondarySpec="c"
                latin:moreKeys="!text/morekeys_c"
                latin:keyHintLabel="\\"
                latin:keyHintLabelLeft="-"
                latin:additionalMoreKeys="-,\\" />
            <Key latin:keySpec="e"
                latin:keySecondarySpec="s"
                latin:moreKeys="!text/morekeys_e"
                latin:keyHintLabel="="
                latin:keyHintLabelLeft="|"
                latin:additionalMoreKeys="\|,=" />
            <Key latin:keySpec="a"
                latin:keySecondarySpec="r"
                latin:moreKeys="!text/morekeys_a"
                latin:keyHintLabel="]"
                latin:keyHintLabelLeft="["
                latin:additionalMoreKeys="[,]" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_o"
                latin:keyHintLabel="&gt;"
                latin:keyHintLabelLeft="&lt;"
                latin:additionalMoreKeys="&lt;,&gt;" />
            <!-- U+00AB: "«" LEFT-POINTING DOUBLE ANGLE QUOTATION MARK in moreKeys -->
            <Key latin:keySpec="z"
                latin:keySecondarySpec=","
                latin:moreKeys="&#x00AB;"
                latin:keyHintLabelLeft="{"
                latin:additionalMoreKeys="{" />
        </case>
        <default>
            <Key latin:keySpec="h"
                latin:keySecondarySpec="c"
                latin:moreKeys="!text/morekeys_c"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="e"
                latin:keySecondarySpec="s"
                latin:moreKeys="!text/morekeys_e"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="a"
                latin:keySecondarySpec="r"
                latin:moreKeys="!text/morekeys_a"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_o"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <!-- U+00AB: "«" LEFT-POINTING DOUBLE ANGLE QUOTATION MARK in moreKeys -->
            <Key latin:keySpec="z"
                latin:keySecondarySpec=","
                latin:moreKeys="&#x00AB;"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="0,9" />
        </default>
    </switch>
</merge>
