<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Georgian row 2: ა·ს  დ·ფ  გ·ჰ  ჯ·კ  ლ·ძ  (5 pairs × 20%; ძ moved up from row 3) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- ა·ს (U+10D0·U+10E1); ა moreKeys: ჺ(U+10FA); ს moreKeys: შ(U+10E8) -->
    <Key latin:keySpec="&#x10D0;" latin:keySecondarySpec="&#x10E1;" latin:moreKeys="&#x10FA;,&#x10E8;" />
    <!-- დ·ფ (U+10D3·U+10E4); ფ moreKeys: ჶ(U+10F6) -->
    <Key latin:keySpec="&#x10D3;" latin:keySecondarySpec="&#x10E4;" latin:moreKeys="&#x10F6;" />
    <!-- გ·ჰ (U+10D2·U+10F0); გ moreKeys: ჹ(U+10F9); ჰ moreKeys: ჵ(U+10F5) -->
    <Key latin:keySpec="&#x10D2;" latin:keySecondarySpec="&#x10F0;" latin:moreKeys="&#x10F9;,&#x10F5;" />
    <!-- ჯ·კ (U+10EF·U+10D9); ჯ moreKeys: ჟ(U+10DF),ჷ(U+10F7) -->
    <Key latin:keySpec="&#x10EF;" latin:keySecondarySpec="&#x10D9;" latin:moreKeys="&#x10DF;,&#x10F7;" />
    <!-- ლ·ძ (U+10DA·U+10EB) -->
    <Key latin:keySpec="&#x10DA;" latin:keySecondarySpec="&#x10EB;" />
</merge>
