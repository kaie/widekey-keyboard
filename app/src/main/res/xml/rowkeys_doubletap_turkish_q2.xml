<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Turkish Q row 2: a·s  d·f  g·h  j·k  l·ş  i·ç  (6 pairs × 16.667%)
     ç moved UP from row 3 to pair with i. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="a"
        latin:keySecondarySpec="s"
        latin:moreKeys="!text/morekeys_a,!text/morekeys_s" />
    <Key latin:keySpec="d"
        latin:keySecondarySpec="f"
        latin:moreKeys="!text/morekeys_d" />
    <Key latin:keySpec="g"
        latin:keySecondarySpec="h"
        latin:moreKeys="!text/morekeys_g,!text/morekeys_h" />
    <Key latin:keySpec="j"
        latin:keySecondarySpec="k"
        latin:moreKeys="!text/morekeys_j,!text/morekeys_k" />
    <!-- ş: LATIN SMALL LETTER S WITH CEDILLA -->
    <Key latin:keySpec="l"
        latin:keySecondarySpec="ş"
        latin:moreKeys="!text/morekeys_l" />
    <!-- i: Turkish dotted i  ç: LATIN SMALL LETTER C WITH CEDILLA (moved up) -->
    <Key latin:keySpec="i"
        latin:keySecondarySpec="ç"
        latin:moreKeys="!text/morekeys_i,!text/morekeys_c" />
</merge>
