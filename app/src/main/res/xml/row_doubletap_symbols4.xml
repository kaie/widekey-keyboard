<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap symbols spacebar row.
     ABC(18%) + globe(10%) + space(42%) + ,.(15%) + enter(15%) = 100% -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row
        latin:keyWidth="10%p"
        latin:backgroundType="functional">
        <Key
            latin:keyStyle="toAlphaKeyStyle"
            latin:keyWidth="18%p" />
        <Key latin:keyStyle="languageSwitchKeyStyle"
            latin:keyWidth="10%p" />
        <Key latin:keyStyle="spaceKeyStyle"
            latin:keyWidth="42%p" />
        <!-- Merged comma·period doubletap key: single-tap=comma, double-tap=period -->
        <Key
            latin:keySpec=","
            latin:keySecondarySpec="."
            latin:keyWidth="15%p"
            latin:keyLabelFlags="hasPopupHint"
            latin:moreKeys="!text/morekeys_period"
            latin:backgroundType="functional" />
        <Key
            latin:keyStyle="enterKeyStyle"
            latin:keyWidth="15%p" />
    </Row>
</merge>
