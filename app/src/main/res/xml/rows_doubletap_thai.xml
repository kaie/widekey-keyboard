<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Thai layout rows.
     Row 1: 6 pairs @ 16.667% = 100%
     Row 2: 6 pairs @ 16.667% = 100%
     Row 3: 6 pairs @ 16.667% = 100% (rowkeys_thai3 + kho_khuat merged)
     Row 4: shift(14%) + 5 pairs @ 14.4% + delete(fillRight)
     Row 5: doubletap spacebar row -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row
        latin:keyWidth="16.667%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_thai1" />
    </Row>
    <Row
        latin:keyWidth="16.667%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_thai2" />
    </Row>
    <Row
        latin:keyWidth="16.667%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_thai3" />
    </Row>
    <Row
        latin:keyWidth="14.4%p"
        latin:keyLabelFlags="fontNormal">
        <Key
            latin:keyStyle="shiftKeyStyle"
            latin:keyWidth="14%p" />
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_thai4" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyWidth="fillRight" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_qwerty4" />
</merge>
