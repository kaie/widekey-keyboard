<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Bépo row 1: b·é  p·o  w·v  d·l  j·z  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <Key latin:keySpec="b"
                latin:keySecondarySpec="é"
                latin:moreKeys="!text/morekeys_e"
                latin:keyHintLabel="\\"
                latin:keyHintLabelLeft="_"
                latin:additionalMoreKeys="_,\\" />
            <Key latin:keySpec="p"
                latin:keySecondarySpec="o"
                latin:moreKeys="!text/morekeys_o"
                latin:keyHintLabel="="
                latin:keyHintLabelLeft="|"
                latin:additionalMoreKeys="\|,=" />
            <Key latin:keySpec="w"
                latin:keySecondarySpec="v"
                latin:moreKeys="!text/morekeys_w,!text/morekeys_v"
                latin:keyHintLabel="]"
                latin:keyHintLabelLeft="["
                latin:additionalMoreKeys="[,]" />
            <Key latin:keySpec="d"
                latin:keySecondarySpec="l"
                latin:moreKeys="!text/morekeys_d,!text/morekeys_l"
                latin:keyHintLabel="&gt;"
                latin:keyHintLabelLeft="&lt;"
                latin:additionalMoreKeys="&lt;,&gt;" />
            <Key latin:keySpec="j"
                latin:keySecondarySpec="z"
                latin:moreKeys="!text/morekeys_j,!text/morekeys_z"
                latin:keyHintLabel="}"
                latin:keyHintLabelLeft="{"
                latin:additionalMoreKeys="},{" />
        </case>
        <default>
            <Key latin:keySpec="b"
                latin:keySecondarySpec="é"
                latin:moreKeys="!text/morekeys_e"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="p"
                latin:keySecondarySpec="o"
                latin:moreKeys="!text/morekeys_o"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="w"
                latin:keySecondarySpec="v"
                latin:moreKeys="!text/morekeys_w,!text/morekeys_v"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="d"
                latin:keySecondarySpec="l"
                latin:moreKeys="!text/morekeys_d,!text/morekeys_l"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="j"
                latin:keySecondarySpec="z"
                latin:moreKeys="!text/morekeys_j,!text/morekeys_z"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="0,9" />
        </default>
    </switch>
</merge>
