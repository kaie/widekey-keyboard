<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Bépo row 1: b·é  p·o  w·v  d·l  j·z  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="b"
        latin:keySecondarySpec="é"
        latin:moreKeys="!text/morekeys_e" />
    <Key latin:keySpec="p"
        latin:keySecondarySpec="o"
        latin:moreKeys="!text/morekeys_o" />
    <Key latin:keySpec="w"
        latin:keySecondarySpec="v"
        latin:moreKeys="!text/morekeys_w,!text/morekeys_v" />
    <Key latin:keySpec="d"
        latin:keySecondarySpec="l"
        latin:moreKeys="!text/morekeys_d,!text/morekeys_l" />
    <Key latin:keySpec="j"
        latin:keySecondarySpec="z"
        latin:moreKeys="!text/morekeys_j,!text/morekeys_z" />
</merge>
