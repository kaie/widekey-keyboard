<?xml version="1.0" encoding="utf-8"?>
<!-- Shared RTL doubletap symbols spacebar row (Hebrew and Arabic).
     toAlpha(15%) + _·,(15%) + space(40%) + /·.(15%) + enter(15%) = 100%
     RTL convention: single-tap=right char → comma and period are single-tap. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row
        latin:keyWidth="10%p"
        latin:backgroundType="functional">
        <Key
            latin:keyStyle="toAlphaKeyStyle"
            latin:keyWidth="15%p" />
        <!-- _·, doubletap: single-tap=comma, double-tap=underscore (RTL convention) -->
        <Key
            latin:keySpec="_"
            latin:keySecondarySpec=","
            latin:keyWidth="15%p" />
        <Key
            latin:keyStyle="spaceKeyStyle"
            latin:keyWidth="40%p" />
        <!-- /·. doubletap: single-tap=period, double-tap=slash (RTL convention) -->
        <Key
            latin:keySpec="/"
            latin:keySecondarySpec="."
            latin:keyWidth="15%p"
            latin:moreKeys="&#x2026;" />
        <Key
            latin:keyStyle="enterKeyStyle"
            latin:keyWidth="15%p" />
    </Row>
</merge>
