<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Mongolian layout rows.
     Row 1: 5 pairs + 1 solo × 16.667% = 100%
     Row 2: 5 pairs + 1 solo × 16.667% = 100%
     Row 3: shift(10.8%) + 4 pairs + 1 solo × 14.2% + delete(fillRight) ≈ 100%
     Row 4: doubletap spacebar row -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row latin:keyWidth="16.667%p">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_mongolian1" />
    </Row>
    <Row latin:keyWidth="16.667%p">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_mongolian2" />
    </Row>
    <Row latin:keyWidth="14.2%p">
        <Key
            latin:keyStyle="shiftKeyStyle"
            latin:keyWidth="10.8%p" />
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_mongolian3" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyWidth="fillRight" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_qwerty4" />
</merge>
