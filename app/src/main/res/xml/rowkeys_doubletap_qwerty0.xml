<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap number row: 5 wide digit pairs.
     1·2  3·4  5·6  7·8  9·0 -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="1" latin:keySecondarySpec="2"
        latin:moreKeys="!text/morekeys_symbols_1,!text/morekeys_symbols_2" />
    <Key latin:keySpec="3" latin:keySecondarySpec="4"
        latin:moreKeys="!text/morekeys_symbols_3,!text/morekeys_symbols_4" />
    <Key latin:keySpec="5" latin:keySecondarySpec="6"
        latin:moreKeys="!text/morekeys_symbols_5" />
    <Key latin:keySpec="7" latin:keySecondarySpec="8"
        latin:moreKeys="!text/morekeys_symbols_7" />
    <Key latin:keySpec="9" latin:keySecondarySpec="0"
        latin:moreKeys="!text/morekeys_symbols_0" />
</merge>
