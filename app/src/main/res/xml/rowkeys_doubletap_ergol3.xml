<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Ergol row 3: z·x  v·b  h·g  [solo:k]  (3 pairs + 1 solo × 17.75%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="z"
        latin:keySecondarySpec="x"
        latin:moreKeys="!text/morekeys_z,!text/morekeys_x"
        latin:keyHintLabelLeft="~"
        latin:additionalMoreKeys="~" />
    <Key latin:keySpec="v"
        latin:keySecondarySpec="b"
        latin:moreKeys="!text/morekeys_v" />
    <Key latin:keySpec="h"
        latin:keySecondarySpec="g"
        latin:moreKeys="!text/morekeys_h,!text/morekeys_g" />
    <!-- Solo key: k -->
    <Key latin:keySpec="k"
        latin:moreKeys="!text/morekeys_k" />
</merge>
