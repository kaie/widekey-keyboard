<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Nepali Romanized layout rows.
     Row 1: 5 pairs + 1 solo @ 16.667% = 100%
     Row 2: 5 pairs + 1 solo @ 16.667% = 100%
     Row 3: shift(14%) + 4 pairs @ 18% + delete(14%) = 100%
     Row 4: doubletap spacebar row -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row
        latin:keyWidth="16.667%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_nepali_romanized1" />
    </Row>
    <Row
        latin:keyWidth="16.667%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_nepali_romanized2" />
    </Row>
    <Row
        latin:keyWidth="18%p"
        latin:keyLabelFlags="fontNormal">
        <Key
            latin:keyStyle="shiftKeyStyle"
            latin:keyWidth="14%p" />
        <include
            latin:keyXPos="14%p"
            latin:keyboardLayout="@xml/rowkeys_doubletap_nepali_romanized3" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyXPos="86%p"
            latin:keyWidth="14%p" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_qwerty4" />
</merge>
