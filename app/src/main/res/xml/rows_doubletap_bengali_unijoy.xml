<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Bengali Unijoy keyboard rows. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row
        latin:keyWidth="20%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_bengali_unijoy1" />
    </Row>
    <Row
        latin:keyWidth="18%p"
        latin:keyLabelFlags="fontNormal">
        <include
            latin:keyboardLayout="@xml/rowkeys_doubletap_bengali_unijoy2"
            latin:keyXPos="5%p" />
    </Row>
    <Row
        latin:keyWidth="17.75%p"
        latin:keyLabelFlags="fontNormal">
        <Key
            latin:keyStyle="shiftKeyStyle"
            latin:keyWidth="14%p" />
        <include
            latin:keyXPos="15%p"
            latin:keyboardLayout="@xml/rowkeys_doubletap_bengali_unijoy3" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyXPos="86%p"
            latin:keyWidth="14%p" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_qwerty4" />
</merge>
