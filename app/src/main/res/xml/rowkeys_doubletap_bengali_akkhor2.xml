<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Bengali Akkhor row 2: 5 pairs + 1 solo at 16.667%p -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:keyboardLayoutSetElement="alphabetManualShifted|alphabetShiftLocked">
            <!-- Shifted: অ · শ -->
            <Key
                latin:keySpec="&#x0985;"
                latin:keySecondarySpec="&#x09B6;" />
            <!-- ড · ঢ় -->
            <Key
                latin:keySpec="&#x09A1;"
                latin:keySecondarySpec="&#x09DD;" />
            <!-- ঘ · হ -->
            <Key
                latin:keySpec="&#x0998;"
                latin:keySecondarySpec="&#x09B9;" />
            <!-- ঝ · খ -->
            <Key
                latin:keySpec="&#x099D;"
                latin:keySecondarySpec="&#x0996;" />
            <!-- ৎ · ঈ -->
            <Key
                latin:keySpec="&#x09CE;"
                latin:keySecondarySpec="&#x0988;" />
            <!-- ঊ solo -->
            <Key latin:keySpec="&#x098A;" />
        </case>
        <default>
            <!-- Unshifted: া · স -->
            <Key
                latin:keySpec="&#x09BE;"
                latin:keySecondarySpec="&#x09B8;"
                latin:moreKeys="&#x0986;" />
            <!-- দ · ৃ -->
            <Key
                latin:keySpec="&#x09A6;"
                latin:keySecondarySpec="&#x09C3;"
                latin:moreKeys="&#x098B;" />
            <!-- গ · ্ -->
            <Key
                latin:keySpec="&#x0997;"
                latin:keySecondarySpec="&#x09CD;" />
            <!-- জ · ক -->
            <Key
                latin:keySpec="&#x099C;"
                latin:keySecondarySpec="&#x0995;" />
            <!-- ল · ই -->
            <Key
                latin:keySpec="&#x09B2;"
                latin:keySecondarySpec="&#x0987;" />
            <!-- উ solo -->
            <Key latin:keySpec="&#x0989;" />
        </default>
    </switch>
</merge>
