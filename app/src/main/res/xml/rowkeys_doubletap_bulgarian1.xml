<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Bulgarian row 1: я·в е·р т·ъ у·и о·п [solo:ч] (5 pairs + 1 solo × 16.667%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <!-- я·в -->
            <Key latin:keySpec="&#x044F;" latin:keySecondarySpec="&#x0432;" />
            <!-- е·р -->
            <Key latin:keySpec="&#x0435;" latin:keySecondarySpec="&#x0440;" />
            <!-- т·ъ -->
            <Key latin:keySpec="&#x0442;" latin:keySecondarySpec="&#x044A;" />
            <!-- у·и (и has moreKey: ѝ U+045D) -->
            <Key latin:keySpec="&#x0443;" latin:keySecondarySpec="&#x0438;"
                latin:moreKeys="&#x045D;" />
            <!-- о·п -->
            <Key latin:keySpec="&#x043E;" latin:keySecondarySpec="&#x043F;" />
        </case>
        <default>
            <Key latin:keySpec="&#x044F;" latin:keySecondarySpec="&#x0432;"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="&#x0435;" latin:keySecondarySpec="&#x0440;"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="&#x0442;" latin:keySecondarySpec="&#x044A;"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="&#x0443;" latin:keySecondarySpec="&#x0438;"
                latin:moreKeys="&#x045D;"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="&#x043E;" latin:keySecondarySpec="&#x043F;"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="9,0" />
        </default>
    </switch>
    <!-- solo: ч -->
    <Key latin:keySpec="&#x0447;" />
</merge>
