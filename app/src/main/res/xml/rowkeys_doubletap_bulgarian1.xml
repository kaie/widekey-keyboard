<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Bulgarian row 1: я·в е·р т·ъ у·и о·п [solo:ч] (5 pairs + 1 solo × 16.667%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- я·в -->
    <Key latin:keySpec="&#x044F;" latin:keySecondarySpec="&#x0432;" />
    <!-- е·р -->
    <Key latin:keySpec="&#x0435;" latin:keySecondarySpec="&#x0440;" />
    <!-- т·ъ -->
    <Key latin:keySpec="&#x0442;" latin:keySecondarySpec="&#x044A;" />
    <!-- у·и (и has moreKey: ѝ U+045D) -->
    <Key latin:keySpec="&#x0443;" latin:keySecondarySpec="&#x0438;"
        latin:moreKeys="&#x045D;" />
    <!-- о·п -->
    <Key latin:keySpec="&#x043E;" latin:keySecondarySpec="&#x043F;" />
    <!-- solo: ч -->
    <Key latin:keySpec="&#x0447;" />
</merge>
