<?xml version="1.0" encoding="utf-8"?>
<!-- Farsi doubletap spacebar row.
     With globe:    ?123(18%) + globe(12%) + space(30%) + ZWNJ(10%) + ،·.(15%) + enter(15%) = 100%
     Without globe: ?123(18%) + space(42%) + ZWNJ(10%) + ،·.(15%) + enter(15%) = 100%
     RTL: single-tap on ،·. key = ، (Arabic comma), double-tap = . (period) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row
        latin:keyWidth="10%p"
        latin:backgroundType="functional">
        <Key
            latin:keyStyle="toSymbolKeyStyle"
            latin:keyWidth="18%p" />
        <switch>
            <case latin:languageSwitchKeyEnabled="true">
                <Key latin:keyStyle="languageSwitchKeyStyle"
                    latin:keyWidth="12%p" />
                <Key latin:keyStyle="spaceKeyStyle"
                    latin:keyWidth="30%p" />
            </case>
            <default>
                <Key latin:keyStyle="spaceKeyStyle"
                    latin:keyWidth="42%p" />
            </default>
        </switch>
        <!-- U+200C: ZERO WIDTH NON-JOINER  long-press: U+200D ZERO WIDTH JOINER -->
        <Key
            latin:keyStyle="zwnjKeyStyle"
            latin:keyWidth="10%p" />
        <!-- ،·. doubletap: RTL single-tap=. (period), double-tap=، (Arabic comma U+060C) -->
        <Key
            latin:keySpec="&#x060C;"
            latin:keySecondarySpec="."
            latin:keyWidth="15%p"
            latin:moreKeys="&#x061F;,&#x2026;,&#x061B;"
            latin:backgroundType="functional" />
        <Key
            latin:keyStyle="enterKeyStyle"
            latin:keyWidth="15%p" />
    </Row>
</merge>
