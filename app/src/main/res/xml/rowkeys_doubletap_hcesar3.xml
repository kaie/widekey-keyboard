<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap HCesar row 3: ç·j  b·f  v·g  [solo:k]  (3 pairs + 1 solo × 17.75%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="ç"
        latin:keySecondarySpec="j"
        latin:keyHintLabel="&quot;"
        latin:keyHintLabelLeft="*"
        latin:additionalMoreKeys="*,&quot;" />
    <Key latin:keySpec="b"
        latin:keySecondarySpec="f"
        latin:keyHintLabel=":"
        latin:keyHintLabelLeft="'"
        latin:additionalMoreKeys="',:" />
    <Key latin:keySpec="v"
        latin:keySecondarySpec="g"
        latin:moreKeys="!text/morekeys_g"
        latin:keyHintLabel="!"
        latin:keyHintLabelLeft=";"
        latin:additionalMoreKeys=";,!" />
    <!-- Solo key: k -->
    <Key latin:keySpec="k"
        latin:moreKeys="!text/morekeys_k" />
</merge>
