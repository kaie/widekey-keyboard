<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Malayalam keyboard rows. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row
        latin:keyWidth="16.667%p"
        latin:keyLabelFlags="fontNormal|autoXScale">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_malayalam1" />
    </Row>
    <Row
        latin:keyWidth="16.667%p"
        latin:keyLabelFlags="fontNormal|autoXScale">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_malayalam2" />
    </Row>
    <Row
        latin:keyWidth="18%p"
        latin:keyLabelFlags="fontNormal|autoXScale">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_malayalam3" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyWidth="fillRight" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_qwerty4" />
</merge>
