<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap QWERTZ row 3: y·x  c·v  b·n  (3 pairs, each ~23.67% of keyboard width)
     Row 3 letter area = 86% - 15% = 71%; 71% / 3 = 23.667% per key. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="y"
        latin:keySecondarySpec="x"
        latin:moreKeys="!text/morekeys_y" />
    <Key latin:keySpec="c"
        latin:keySecondarySpec="v"
        latin:moreKeys="!text/morekeys_c,!text/morekeys_v" />
    <Key latin:keySpec="b"
        latin:keySecondarySpec="n"
        latin:moreKeys="!text/morekeys_n" />
</merge>
