<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Hindi row 3: 4 pairs + 1 solo @ 15.68%
     Unshifted: ॉ·ं  म·न  व·ल  स·य  [़ solo]
     Shifted:   ऑ·ँ  ण·ऩ  ळ·श  ष·ृ  [ञ solo] -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:keyboardLayoutSetElement="alphabetManualShifted|alphabetShiftLocked">
            <!-- Pair 1: ऑ · ँ (U+0911 · U+0901 candrabindu) -->
            <Key
                latin:keySpec="&#x0911;"
                latin:keySecondarySpec="&#x0901;" />
            <!-- Pair 2: ण · ऩ (U+0923 · U+0929) -->
            <Key
                latin:keySpec="&#x0923;"
                latin:keySecondarySpec="&#x0929;" />
            <!-- Pair 3: ळ · श (U+0933 · U+0936); moreKeys: ऴ (from ळ) -->
            <Key
                latin:keySpec="&#x0933;"
                latin:keySecondarySpec="&#x0936;"
                latin:moreKeys="&#x0934;" />
            <!-- Pair 4: ष · ृ (U+0937 · U+0943 vocalic-r sign) -->
            <Key
                latin:keySpec="&#x0937;"
                latin:keySecondarySpec="&#x0943;" />
            <!-- Solo: ञ (U+091E) -->
            <Key
                latin:keySpec="&#x091E;"
                latin:keyWidth="15.68%p" />
        </case>
        <default>
            <!-- Pair 1: ॉ · ं (U+0949 candra-o sign · U+0902 anusvara) -->
            <Key
                latin:keySpec="&#x0949;"
                latin:keySecondarySpec="&#x0902;" />
            <!-- Pair 2: म · न (U+092E · U+0928); moreKeys: OM (from म), ञ,ङ,ऩ (from न) -->
            <Key
                latin:keySpec="&#x092E;"
                latin:keySecondarySpec="&#x0928;"
                latin:moreKeys="&#x0950;,&#x091E;,&#x0919;,&#x0928;&#x093C;" />
            <!-- Pair 3: व · ल (U+0935 · U+0932); moreKeys: ऌ,ॡ (from ल) -->
            <Key
                latin:keySpec="&#x0935;"
                latin:keySecondarySpec="&#x0932;"
                latin:moreKeys="&#x090C;,&#x0961;" />
            <!-- Pair 4: स · य (U+0938 · U+092F); moreKeys: य़ (from य) -->
            <Key
                latin:keySpec="&#x0938;"
                latin:keySecondarySpec="&#x092F;"
                latin:moreKeys="&#x095F;" />
            <!-- Solo: ़ (U+093C nukta); moreKeys: ॽ,॰,ऽ (from hindi case) -->
            <Key
                latin:keySpec="&#x093C;"
                latin:keyWidth="15.68%p"
                latin:moreKeys="&#x097D;,&#x0970;,&#x093D;" />
        </default>
    </switch>
</merge>
