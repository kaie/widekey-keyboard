<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Urdu layout rows.
     Row 1: 5 pairs @ 20% = 100%
     Row 2: 5 pairs @ 20% = 100% (م/؁ moved here from original row 3)
     Row 3: shift(14%) + 3 pairs @ 24% + delete(fillRight≈14%) = 100%
     Row 4: doubletap spacebar row -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row
        latin:keyWidth="20%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_urdu1" />
    </Row>
    <Row
        latin:keyWidth="20%p"
        latin:keyLabelFlags="fontNormal">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_urdu2" />
    </Row>
    <Row
        latin:keyWidth="24%p"
        latin:keyLabelFlags="fontNormal">
        <Key
            latin:keyStyle="shiftKeyStyle"
            latin:keyWidth="14%p" />
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_urdu3" />
        <Key
            latin:keyStyle="deleteKeyStyle"
            latin:keyWidth="fillRight" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_qwerty4" />
</merge>
