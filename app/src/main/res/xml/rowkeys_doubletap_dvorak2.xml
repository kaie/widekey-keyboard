<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Dvorak row 2: a·o  e·u  i·d  h·t  n·s  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="a" latin:keySecondarySpec="o" />
    <Key latin:keySpec="e" latin:keySecondarySpec="u" />
    <Key latin:keySpec="i" latin:keySecondarySpec="d" />
    <Key latin:keySpec="h" latin:keySecondarySpec="t" />
    <Key latin:keySpec="n" latin:keySecondarySpec="s" />
</merge>
