<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Dvorak row 2: a·o  e·u  i·d  h·t  n·s  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="a" latin:keySecondarySpec="o" latin:moreKeys="!text/morekeys_a,!text/morekeys_o"
        latin:keyHintLabel="#"
        latin:keyHintLabelLeft="\@"
        latin:additionalMoreKeys="\@,#" />
    <Key latin:keySpec="e" latin:keySecondarySpec="u" latin:moreKeys="!text/morekeys_e,!text/morekeys_u"
        latin:keyHintLabel="%"
        latin:keyHintLabelLeft="$"
        latin:additionalMoreKeys="$,%" />
    <Key latin:keySpec="i" latin:keySecondarySpec="d" latin:moreKeys="!text/morekeys_i,!text/morekeys_d"
        latin:keyHintLabel="-"
        latin:keyHintLabelLeft="&amp;"
        latin:additionalMoreKeys="&amp;,-" />
    <Key latin:keySpec="h" latin:keySecondarySpec="t" latin:moreKeys="!text/morekeys_h,!text/morekeys_t"
        latin:keyHintLabel="("
        latin:keyHintLabelLeft="+"
        latin:additionalMoreKeys="+,(" />
    <Key latin:keySpec="n" latin:keySecondarySpec="s" latin:moreKeys="!text/morekeys_n,!text/morekeys_s"
        latin:keyHintLabel="/"
        latin:keyHintLabelLeft=")"
        latin:additionalMoreKeys="/,)" />
</merge>
