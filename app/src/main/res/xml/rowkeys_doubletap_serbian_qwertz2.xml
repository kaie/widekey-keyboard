<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Serbian QWERTZ row 2: a·s  d·f  g·h  j·k  l·č  ć·ž  (6 pairs × 16.667%)
     ž (U+017E) moved UP from row 3 to pair with ć (U+0107). -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="a"
        latin:keySecondarySpec="s"
        latin:moreKeys="!text/morekeys_a,!text/morekeys_s" />
    <Key latin:keySpec="d"
        latin:keySecondarySpec="f"
        latin:moreKeys="!text/morekeys_d" />
    <Key latin:keySpec="g"
        latin:keySecondarySpec="h"
        latin:moreKeys="!text/morekeys_g,!text/morekeys_h" />
    <Key latin:keySpec="j"
        latin:keySecondarySpec="k"
        latin:moreKeys="!text/morekeys_j,!text/morekeys_k" />
    <!-- U+010D: "č" LATIN SMALL LETTER C WITH CARON -->
    <Key latin:keySpec="l"
        latin:keySecondarySpec="&#x010D;"
        latin:moreKeys="!text/morekeys_l" />
    <!-- U+0107: "ć"  U+017E: "ž" -->
    <Key latin:keySpec="&#x0107;"
        latin:keySecondarySpec="&#x017E;" />
</merge>
