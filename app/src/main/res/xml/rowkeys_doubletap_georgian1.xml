<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Georgian row 1: ქ·წ  ე·რ  ტ·ყ  უ·ი  ო·პ  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- ქ·წ (U+10E5·U+10EC) -->
    <Key latin:keySpec="&#x10E5;" latin:keySecondarySpec="&#x10EC;" />
    <!-- ე·რ (U+10D4·U+10E0) -->
    <Key latin:keySpec="&#x10D4;" latin:keySecondarySpec="&#x10E0;" />
    <!-- ტ·ყ (U+10E2·U+10E7) -->
    <Key latin:keySpec="&#x10E2;" latin:keySecondarySpec="&#x10E7;" />
    <!-- უ·ი (U+10E3·U+10D8) -->
    <Key latin:keySpec="&#x10E3;" latin:keySecondarySpec="&#x10D8;" />
    <!-- ო·პ (U+10DD·U+10DE) -->
    <Key latin:keySpec="&#x10DD;" latin:keySecondarySpec="&#x10DE;" />
</merge>
