<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Arabic row 3: 5 pairs × 20%
     Pairs (left·right): ذ·ء  ؤ·ر  ى·ة  و·ز  ظ·د -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- ذ·ء -->
    <Key
        latin:keySpec="&#x0630;"
        latin:keySecondarySpec="&#x0621;" />
    <!-- ؤ·ر -->
    <Key
        latin:keySpec="&#x0624;"
        latin:keySecondarySpec="&#x0631;" />
    <!-- ى·ة -->
    <Key
        latin:keySpec="&#x0649;"
        latin:keySecondarySpec="&#x0629;"
        latin:moreKeys="&#x0626;" />
    <!-- و·ز -->
    <Key
        latin:keySpec="&#x0648;"
        latin:keySecondarySpec="&#x0632;"
        latin:moreKeys="&#x0698;" />
    <!-- ظ·د -->
    <Key
        latin:keySpec="&#x0638;"
        latin:keySecondarySpec="&#x062F;" />
</merge>
