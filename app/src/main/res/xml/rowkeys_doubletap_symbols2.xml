<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap symbols row 2: @·* #·€(currency) %·& -·+ (·) (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="\@" latin:keySecondarySpec="*"
        latin:moreKeys="!text/morekeys_star" />
    <!-- Currency secondary uses same locale detection as key_styles_currency.xml.
         U+2116: "№" NUMERO SIGN  U+00A2: "¢" CENT SIGN  U+20AC: "€" EURO SIGN
         U+00A3: "£" POUND SIGN   U+20B9: "₹" INDIAN RUPEE SIGN -->
    <switch>
        <case latin:countryCode="AD|AT|BE|CY|EE|FI|FR|DE|GR|IE|IT|XK|LU|MT|MO|ME|NL|PT|SM|SK|SI|ES|VA">
            <Key latin:keySpec="\#" latin:keySecondarySpec="&#x20AC;"
                latin:moreKeys="&#x2116;,&#x00A2;" />
        </case>
        <case latin:localeCode="da|de|es|el|fi|fr|it|nl|sk|sl|sv|tr">
            <Key latin:keySpec="\#" latin:keySecondarySpec="&#x20AC;"
                latin:moreKeys="&#x2116;,&#x00A2;" />
        </case>
        <case latin:languageCode="ca|et|lt|lv|lb|mt">
            <Key latin:keySpec="\#" latin:keySecondarySpec="&#x20AC;"
                latin:moreKeys="&#x2116;,&#x00A2;" />
        </case>
        <case latin:countryCode="IN">
            <Key latin:keySpec="\#" latin:keySecondarySpec="&#x20B9;"
                latin:moreKeys="&#x2116;,&#x00A2;" />
        </case>
        <case latin:countryCode="GB">
            <Key latin:keySpec="\#" latin:keySecondarySpec="&#x00A3;"
                latin:moreKeys="&#x2116;,&#x00A2;" />
        </case>
        <default>
            <Key latin:keySpec="\#" latin:keySecondarySpec="$"
                latin:moreKeys="&#x2116;,&#x00A2;" />
        </default>
    </switch>
    <Key latin:keySpec="!text/keyspec_symbols_percent" latin:keySecondarySpec="&amp;"
        latin:moreKeys="!text/morekeys_symbols_percent" />
    <!-- U+2013: "–" EN DASH  U+2014: "—" EM DASH  U+00B7: "·" MIDDLE DOT -->
    <Key latin:keySpec="-" latin:keySecondarySpec="+"
        latin:moreKeys="_,&#x2013;,&#x2014;,&#x00B7;" />
    <Key latin:keySpec="!text/keyspec_left_parenthesis"
        latin:keySecondarySpec="!text/keyspec_right_parenthesis"
        latin:moreKeys="!text/morekeys_left_parenthesis" />
</merge>
