<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Colemak row 1: q·w  f·p  g·j  l·u  y·;  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="q" latin:keySecondarySpec="w" />
    <Key latin:keySpec="f" latin:keySecondarySpec="p" />
    <Key latin:keySpec="g" latin:keySecondarySpec="j" />
    <Key latin:keySpec="l" latin:keySecondarySpec="u" />
    <Key latin:keySpec="y" latin:keySecondarySpec=";" />
</merge>
