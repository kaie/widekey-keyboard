<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Colemak row 1: q·w  f·p  g·j  l·u  y·;  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <Key latin:keySpec="q" latin:keySecondarySpec="w" latin:moreKeys="!text/morekeys_w"
                latin:keyHintLabel="\\"
                latin:keyHintLabelLeft="_"
                latin:additionalMoreKeys="_,\\" />
            <Key latin:keySpec="f" latin:keySecondarySpec="p"
                latin:keyHintLabel="="
                latin:keyHintLabelLeft="|"
                latin:additionalMoreKeys="\|,=" />
            <Key latin:keySpec="g" latin:keySecondarySpec="j" latin:moreKeys="!text/morekeys_g,!text/morekeys_j"
                latin:keyHintLabel="]"
                latin:keyHintLabelLeft="["
                latin:additionalMoreKeys="[,]" />
            <Key latin:keySpec="l" latin:keySecondarySpec="u" latin:moreKeys="!text/morekeys_l,!text/morekeys_u"
                latin:keyHintLabel="&gt;"
                latin:keyHintLabelLeft="&lt;"
                latin:additionalMoreKeys="&gt;,&lt;" />
            <Key latin:keySpec="y" latin:keySecondarySpec=";" latin:moreKeys="!text/morekeys_y"
                latin:keyHintLabelLeft="{"
                latin:additionalMoreKeys="{" />
        </case>
        <default>
            <Key latin:keySpec="q" latin:keySecondarySpec="w" latin:moreKeys="!text/morekeys_w"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="f" latin:keySecondarySpec="p"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="g" latin:keySecondarySpec="j" latin:moreKeys="!text/morekeys_g,!text/morekeys_j"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="l" latin:keySecondarySpec="u" latin:moreKeys="!text/morekeys_l,!text/morekeys_u"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="y" latin:keySecondarySpec=";" latin:moreKeys="!text/morekeys_y"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="0,9" />
        </default>
    </switch>
</merge>
