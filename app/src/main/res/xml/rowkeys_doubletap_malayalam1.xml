<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Malayalam row 1: 5 pairs + 1 solo at 16.667%p -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- ് · ാ (virama, vowel sign AA) -->
    <Key
        latin:keySpec="&#x0D4D;"
        latin:keySecondarySpec="&#x0D3E;"
        latin:moreKeys="&#x0D05;,&#x0D06;" />
    <!-- ി · ീ (vowel signs I, II) -->
    <Key
        latin:keySpec="&#x0D3F;"
        latin:keySecondarySpec="&#x0D40;"
        latin:moreKeys="&#x0D07;,&#x0D08;" />
    <!-- ു · ൂ (vowel signs U, UU) -->
    <Key
        latin:keySpec="&#x0D41;"
        latin:keySecondarySpec="&#x0D42;"
        latin:moreKeys="&#x0D09;,&#x0D0A;" />
    <!-- ൃ · െ (vowel sign vocalic R, vowel sign E) -->
    <Key
        latin:keySpec="&#x0D43;"
        latin:keySecondarySpec="&#x0D46;"
        latin:moreKeys="&#x0D0B;,&#x0D0E;,&#x0D10;,&#x0D48;" />
    <!-- േ · ൊ (vowel signs EE, O) -->
    <Key
        latin:keySpec="&#x0D47;"
        latin:keySecondarySpec="&#x0D4A;"
        latin:moreKeys="&#x0D0F;,&#x0D12;" />
    <!-- ോ solo (vowel sign OO) -->
    <Key
        latin:keySpec="&#x0D4B;"
        latin:moreKeys="&#x0D13;,&#x0D14;,&#x0D57;" />
</merge>
