<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Ergol row 1: q·c  o·p  w·j  m·d  !·y  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <Key latin:keySpec="q"
                latin:keySecondarySpec="c"
                latin:moreKeys="!text/morekeys_q,!text/morekeys_c"
                latin:keyHintLabel="&lt;"
                latin:keyHintLabelLeft="^"
                latin:additionalMoreKeys="^,&lt;" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_o"
                latin:keyHintLabel="$"
                latin:keyHintLabelLeft="&gt;"
                latin:additionalMoreKeys="&gt;,$" />
            <Key latin:keySpec="w"
                latin:keySecondarySpec="j"
                latin:moreKeys="!text/morekeys_w,!text/morekeys_j"
                latin:keyHintLabel="\@"
                latin:keyHintLabelLeft="%"
                latin:additionalMoreKeys="%,\@" />
            <Key latin:keySpec="m"
                latin:keySecondarySpec="d"
                latin:moreKeys="!text/morekeys_d"
                latin:keyHintLabel="*"
                latin:keyHintLabelLeft="&amp;"
                latin:additionalMoreKeys="&amp;,*" />
            <Key latin:keySpec="!"
                latin:keySecondarySpec="y"
                latin:moreKeys="!text/morekeys_!,!text/morekeys_y"
                latin:keyHintLabel="`"
                latin:keyHintLabelLeft="'"
                latin:additionalMoreKeys="`,'" />
        </case>
        <default>
            <Key latin:keySpec="q"
                latin:keySecondarySpec="c"
                latin:moreKeys="!text/morekeys_q,!text/morekeys_c"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_o"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="w"
                latin:keySecondarySpec="j"
                latin:moreKeys="!text/morekeys_w,!text/morekeys_j"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="m"
                latin:keySecondarySpec="d"
                latin:moreKeys="!text/morekeys_d"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="!"
                latin:keySecondarySpec="y"
                latin:moreKeys="!text/morekeys_!,!text/morekeys_y"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="0,9" />
        </default>
    </switch>
</merge>
