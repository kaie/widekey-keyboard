<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Nepali Traditional row 3: 4 pairs + 1 solo @ 15.68%
     Unshifted: श·ह  अ·ख  द·ल  े·्  [र solo]
     Shifted:   क्·ह्म  ऋ·ॐ  ौ·द्य  ं·ङ  [ै solo] -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:keyboardLayoutSetElement="alphabetManualShifted|alphabetShiftLocked">
            <!-- Pair 1: क् · ह्म -->
            <Key
                latin:keySpec="&#x0915;&#x094D;"
                latin:keySecondarySpec="&#x0939;&#x094D;&#x092E;"
                latin:keyLabelFlags="followKeyLetterRatio" />
            <!-- Pair 2: ऋ · ॐ -->
            <Key
                latin:keySpec="&#x090B;"
                latin:keySecondarySpec="&#x0950;" />
            <!-- Pair 3: ौ · द्य (vowelAU · U+0926+U+094D+U+092F) -->
            <!-- Because the font rendering system prior to API version 16 can't automatically
                 render dotted circle for incomplete combining letter of some scripts, different
                 set of Key definitions are needed based on the API version. -->
            <include latin:keyboardLayout="@xml/keystyle_devanagari_vowel_sign_au" />
            <Key
                latin:keyStyle="baseKeyDevanagariVowelSignAu"
                latin:keySecondarySpec="&#x0926;&#x094D;&#x092F;" />
            <!-- Pair 4: ं · ङ (anusvara · U+0919) -->
            <include latin:keyboardLayout="@xml/keystyle_devanagari_sign_anusvara" />
            <Key
                latin:keyStyle="baseKeyDevanagariSignAnusvara"
                latin:keySecondarySpec="&#x0919;" />
            <!-- Solo: ै (U+0948 vowelAI) -->
            <!-- Because the font rendering system prior to API version 16 can't automatically
                 render dotted circle for incomplete combining letter of some scripts, different
                 set of Key definitions are needed based on the API version. -->
            <include latin:keyboardLayout="@xml/keystyle_devanagari_vowel_sign_ai" />
            <Key
                latin:keyStyle="baseKeyDevanagariVowelSignAi"
                latin:keyWidth="15.68%p" />
        </case>
        <default>
            <!-- Pair 1: श · ह -->
            <Key
                latin:keySpec="&#x0936;"
                latin:keySecondarySpec="&#x0939;" />
            <!-- Pair 2: अ · ख -->
            <Key
                latin:keySpec="&#x0905;"
                latin:keySecondarySpec="&#x0916;" />
            <!-- Pair 3: द · ल -->
            <Key
                latin:keySpec="&#x0926;"
                latin:keySecondarySpec="&#x0932;" />
            <!-- Pair 4: े · ् (vowelE · virama) -->
            <!-- Because the font rendering system prior to API version 16 can't automatically
                 render dotted circle for incomplete combining letter of some scripts, different
                 set of Key definitions are needed based on the API version. -->
            <include latin:keyboardLayout="@xml/keystyle_devanagari_vowel_sign_e" />
            <Key
                latin:keyStyle="baseKeyDevanagariVowelSignE"
                latin:keySecondarySpec="&#x094D;" />
            <!-- Solo: र (U+0930) -->
            <Key
                latin:keySpec="&#x0930;"
                latin:keyWidth="15.68%p"
                latin:moreKeys="&#x0930;&#x0941;" />
        </default>
    </switch>
</merge>
