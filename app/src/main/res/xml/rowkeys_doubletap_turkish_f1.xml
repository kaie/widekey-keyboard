<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Turkish F row 1: f·g  ğ·ı  o·d  r·n  h·p  q·w  (6 pairs × 16.667%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <Key latin:keySpec="f"
                latin:keySecondarySpec="g"
                latin:moreKeys="!text/morekeys_g" />
            <!-- ğ: LATIN SMALL LETTER G WITH BREVE  ı: LATIN SMALL LETTER DOTLESS I -->
            <Key latin:keySpec="ğ"
                latin:keySecondarySpec="ı"
                latin:moreKeys="!text/morekeys_i" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="d"
                latin:moreKeys="!text/morekeys_o,!text/morekeys_d" />
            <Key latin:keySpec="r"
                latin:keySecondarySpec="n"
                latin:moreKeys="!text/morekeys_r,!text/morekeys_n" />
            <Key latin:keySpec="h"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_h" />
            <Key latin:keySpec="q"
                latin:keySecondarySpec="w"
                latin:moreKeys="!text/morekeys_w" />
        </case>
        <default>
            <Key latin:keySpec="f"
                latin:keySecondarySpec="g"
                latin:moreKeys="!text/morekeys_g"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="ğ"
                latin:keySecondarySpec="ı"
                latin:moreKeys="!text/morekeys_i"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="o"
                latin:keySecondarySpec="d"
                latin:moreKeys="!text/morekeys_o,!text/morekeys_d"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="r"
                latin:keySecondarySpec="n"
                latin:moreKeys="!text/morekeys_r,!text/morekeys_n"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="h"
                latin:keySecondarySpec="p"
                latin:moreKeys="!text/morekeys_h"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="9,0" />
            <!-- q·w: no digit assignment (beyond 10 digits) -->
            <Key latin:keySpec="q"
                latin:keySecondarySpec="w"
                latin:moreKeys="!text/morekeys_w" />
        </default>
    </switch>
</merge>
