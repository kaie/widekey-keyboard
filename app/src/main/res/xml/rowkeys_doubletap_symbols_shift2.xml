<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap shifted symbols row 2: ¤₁·¤₂  ¤₃·¤₄  ^·°  =·℅  {·} (5 pairs × 20%)
     For euro locales (e.g. German): ¤₁=£ ¤₂=¥ ¤₃=$ ¤₄=¢
     Secondary specs are hardcoded to the euro-locale values of ¤₂ and ¤₄. -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- U+00A5: "¥" YEN SIGN (moreCurrency2 for euro locales) -->
    <Key latin:keyStyle="moreCurrency1KeyStyle" latin:keySecondarySpec="&#x00A5;" />
    <!-- U+00A2: "¢" CENT SIGN (moreCurrency4 for euro locales) -->
    <Key latin:keyStyle="moreCurrency3KeyStyle" latin:keySecondarySpec="&#x00A2;" />
    <!-- U+00B0: "°" DEGREE SIGN  U+2191-2194: arrows  U+2032-2033: prime signs -->
    <Key latin:keySpec="^" latin:keySecondarySpec="&#x00B0;"
        latin:moreKeys="&#x2191;,&#x2193;,&#x2190;,&#x2192;,&#x2032;,&#x2033;" />
    <!-- U+2105: "℅" CARE OF  U+2260: "≠"  U+2248: "≈"  U+221E: "∞" -->
    <Key latin:keySpec="=" latin:keySecondarySpec="&#x2105;"
        latin:moreKeys="&#x2260;,&#x2248;,&#x221E;" />
    <Key latin:keySpec="!text/keyspec_left_curly_bracket"
        latin:keySecondarySpec="!text/keyspec_right_curly_bracket" />
</merge>
