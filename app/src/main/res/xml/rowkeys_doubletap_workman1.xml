<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Workman row 1: q·d  r·w  b·j  f·u  p·;  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="q" latin:keySecondarySpec="d" />
    <Key latin:keySpec="r" latin:keySecondarySpec="w" />
    <Key latin:keySpec="b" latin:keySecondarySpec="j" />
    <Key latin:keySpec="f" latin:keySecondarySpec="u" />
    <Key latin:keySpec="p" latin:keySecondarySpec=";" />
</merge>
