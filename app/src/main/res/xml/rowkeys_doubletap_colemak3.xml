<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Colemak row 3: z·x  c·v  b·k  [m solo]  (3 pairs + 1 solo × 17.75%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="z" latin:keySecondarySpec="x" />
    <Key latin:keySpec="c" latin:keySecondarySpec="v" />
    <Key latin:keySpec="b" latin:keySecondarySpec="k" />
    <!-- m is solo: outputs immediately without delay -->
    <Key latin:keySpec="m" />
</merge>
