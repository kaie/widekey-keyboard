<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Colemak row 3: z·x  c·v  b·k  [m solo]  (3 pairs + 1 solo × 17.75%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="z" latin:keySecondarySpec="x" latin:moreKeys="!text/morekeys_z"
        latin:keyHintLabel="&quot;"
        latin:keyHintLabelLeft="*"
        latin:additionalMoreKeys="*,&quot;" />
    <Key latin:keySpec="c" latin:keySecondarySpec="v" latin:moreKeys="!text/morekeys_c,!text/morekeys_v"
        latin:keyHintLabel=":"
        latin:keyHintLabelLeft="'"
        latin:additionalMoreKeys="',:" />
    <Key latin:keySpec="b" latin:keySecondarySpec="k" latin:moreKeys="!text/morekeys_k"
        latin:keyHintLabel="!"
        latin:keyHintLabelLeft=";"
        latin:additionalMoreKeys=";,!" />
    <!-- m is solo: outputs immediately without delay -->
    <Key latin:keySpec="m" />
</merge>
