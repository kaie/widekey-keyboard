<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Workman row 3: z·x  m·c  v·k  [l solo]  (3 pairs + 1 solo × 17.75%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="z" latin:keySecondarySpec="x" latin:moreKeys="!text/morekeys_z" />
    <Key latin:keySpec="m" latin:keySecondarySpec="c" latin:moreKeys="!text/morekeys_c,!text/morekeys_v" />
    <Key latin:keySpec="v" latin:keySecondarySpec="k" latin:moreKeys="!text/morekeys_k" />
    <!-- l is solo: outputs immediately without delay -->
    <Key latin:keySpec="l" />
</merge>
