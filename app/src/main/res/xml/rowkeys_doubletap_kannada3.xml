        latin:keySpec="&#x0CAE;"
        latin:keySecondarySpec="&#x0CA8;"
        latin:moreKeys="&#x0CA3;" />
    <!-- ವ · ಲ -->
    <Key
        latin:keySpec="&#x0CB5;"
        latin:keySecondarySpec="&#x0CB2;"
        latin:moreKeys="&#x0CB3;" />
    <!-- ಸ · ಋ -->
    <Key
        latin:keySpec="&#x0CB8;"
        latin:keySecondarySpec="&#x0C8B;"
        latin:moreKeys="&#x0CB6;,&#x0CCD;&#x0CB0;" />
    <!-- ಷ · ಯ -->
    <Key
        latin:keySpec="&#x0CB7;"
        latin:keySecondarySpec="&#x0CAF;"
