<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Farsi row 2: 5 pairs + 1 solo × 16.667%
     Pairs (left·right): ش·س  ی·ب  ل·ا  ت·ن  م·ک  solo: گ -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- ش·س -->
    <Key
        latin:keySpec="&#x0634;"
        latin:keySecondarySpec="&#x0633;" />
    <!-- ی·ب (Farsi Yeh U+06CC) -->
    <Key
        latin:keySpec="&#x06CC;"
        latin:keySecondarySpec="&#x0628;"
        latin:moreKeys="&#x0626;,&#x064A;,&#xFBE8;|&#x0649;" />
    <!-- ل·ا (ا has 5 moreKeys; ل has no lam-alef moreKeys in Farsi) -->
    <Key
        latin:keySpec="&#x0644;"
        latin:keySecondarySpec="&#x0627;"
        latin:moreKeys="!fixedColumnOrder!5,&#x0671;,&#x0621;,&#x0622;,&#x0623;,&#x0625;" />
    <!-- ت·ن -->
    <Key
        latin:keySpec="&#x062A;"
        latin:keySecondarySpec="&#x0646;"
        latin:moreKeys="&#x0629;" />
    <!-- م·ک (Keheh U+06A9) -->
    <Key
        latin:keySpec="&#x0645;"
        latin:keySecondarySpec="&#x06A9;"
        latin:moreKeys="&#x0643;" />
    <!-- گ solo -->
    <Key
        latin:keySpec="&#x06AF;" />
</merge>
