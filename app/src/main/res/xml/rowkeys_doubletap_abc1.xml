<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap ABC row 1: a·b  c·d  e·f  g·h  i·j  (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <switch>
        <case latin:showNumberRow="true">
            <!-- a·b: left=_(a) right=\(b) -->
            <Key latin:keySpec="a" latin:keySecondarySpec="b" latin:moreKeys="!text/morekeys_a"
                latin:keyHintLabel="\\"
                latin:keyHintLabelLeft="_"
                latin:additionalMoreKeys="_,\\" />
            <!-- c·d: left=|(c) right==(d) -->
            <Key latin:keySpec="c" latin:keySecondarySpec="d" latin:moreKeys="!text/morekeys_c,!text/morekeys_d"
                latin:keyHintLabel="="
                latin:keyHintLabelLeft="|"
                latin:additionalMoreKeys="\|,=" />
            <!-- e·f: left=[(e) right=](f) -->
            <Key latin:keySpec="e" latin:keySecondarySpec="f" latin:moreKeys="!text/morekeys_e"
                latin:keyHintLabel="]"
                latin:keyHintLabelLeft="["
                latin:additionalMoreKeys="[,]" />
            <!-- g·h: left=<(g) right=>(h) -->
            <Key latin:keySpec="g" latin:keySecondarySpec="h" latin:moreKeys="!text/morekeys_g,!text/morekeys_h"
                latin:keyHintLabel="&gt;"
                latin:keyHintLabelLeft="&lt;"
                latin:additionalMoreKeys="&lt;,&gt;" />
            <!-- i·j: left={(i) right=}(j) — right-edge: additionalMoreKeys right-first -->
            <Key latin:keySpec="i" latin:keySecondarySpec="j" latin:moreKeys="!text/morekeys_i,!text/morekeys_j"
                latin:keyHintLabel="}"
                latin:keyHintLabelLeft="{"
                latin:additionalMoreKeys="},{" />
        </case>
        <default>
            <Key latin:keySpec="a" latin:keySecondarySpec="b" latin:moreKeys="!text/morekeys_a"
                latin:keyHintLabelLeft="1"
                latin:keyHintLabel="2"
                latin:additionalMoreKeys="1,2" />
            <Key latin:keySpec="c" latin:keySecondarySpec="d" latin:moreKeys="!text/morekeys_c,!text/morekeys_d"
                latin:keyHintLabelLeft="3"
                latin:keyHintLabel="4"
                latin:additionalMoreKeys="3,4" />
            <Key latin:keySpec="e" latin:keySecondarySpec="f" latin:moreKeys="!text/morekeys_e"
                latin:keyHintLabelLeft="5"
                latin:keyHintLabel="6"
                latin:additionalMoreKeys="5,6" />
            <Key latin:keySpec="g" latin:keySecondarySpec="h" latin:moreKeys="!text/morekeys_g,!text/morekeys_h"
                latin:keyHintLabelLeft="7"
                latin:keyHintLabel="8"
                latin:additionalMoreKeys="7,8" />
            <Key latin:keySpec="i" latin:keySecondarySpec="j" latin:moreKeys="!text/morekeys_i,!text/morekeys_j"
                latin:keyHintLabelLeft="9"
                latin:keyHintLabel="0"
                latin:additionalMoreKeys="0,9" />
        </default>
    </switch>
</merge>
