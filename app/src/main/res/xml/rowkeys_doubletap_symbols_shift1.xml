<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap shifted symbols row 1: ~·` |·• √·π ÷·× ¶·∆ (5 pairs × 20%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="~" latin:keySecondarySpec="\`" />
    <!-- U+2022: "•" BULLET -->
    <Key latin:keySpec="|" latin:keySecondarySpec="&#x2022;"
        latin:moreKeys="!text/morekeys_bullet" />
    <!-- U+221A: "√" SQUARE ROOT  U+03C0: "π" GREEK SMALL LETTER PI  U+03A0: "Π" CAPITAL PI -->
    <Key latin:keySpec="&#x221A;" latin:keySecondarySpec="&#x03C0;"
        latin:moreKeys="&#x03A0;" />
    <!-- U+00F7: "÷" DIVISION SIGN  U+00D7: "×" MULTIPLICATION SIGN -->
    <Key latin:keySpec="&#x00F7;" latin:keySecondarySpec="&#x00D7;" />
    <!-- U+00B6: "¶" PILCROW SIGN  U+2206: "∆" INCREMENT  U+00A7: "§" SECTION SIGN -->
    <Key latin:keySpec="&#x00B6;" latin:keySecondarySpec="&#x2206;"
        latin:moreKeys="&#x00A7;" />
</merge>
