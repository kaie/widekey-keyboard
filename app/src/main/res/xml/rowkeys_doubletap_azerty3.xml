<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap AZERTY row 3: w·x  c·v  b·n  [solo:?/']  (3 pairs + 1 solo × 17.75%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Key latin:keySpec="w"
        latin:keySecondarySpec="x"
        latin:moreKeys="!text/morekeys_w"
        latin:keyHintLabel="&quot;"
        latin:keyHintLabelLeft="*"
        latin:additionalMoreKeys="*,&quot;" />
    <Key latin:keySpec="c"
        latin:keySecondarySpec="v"
        latin:moreKeys="!text/morekeys_c,!text/morekeys_v"
        latin:keyHintLabel=":"
        latin:keyHintLabelLeft="'"
        latin:additionalMoreKeys="',:" />
    <Key latin:keySpec="b"
        latin:keySecondarySpec="n"
        latin:moreKeys="!text/morekeys_n"
        latin:keyHintLabel="!"
        latin:keyHintLabelLeft=";"
        latin:additionalMoreKeys=";,!" />
    <!-- Solo key: unshifted=apostrophe, shifted=question mark -->
    <switch>
        <case latin:keyboardLayoutSetElement="alphabetManualShifted|alphabetShiftLockShifted|alphabetShiftLocked">
            <Key latin:keySpec="\?" />
        </case>
        <default>
            <Key latin:keySpec="\'"
                latin:moreKeys="!text/morekeys_single_quote" />
        </default>
    </switch>
</merge>
