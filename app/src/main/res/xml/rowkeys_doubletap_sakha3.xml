<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Sakha row 3: я·ч с·м [row3_5]·т ь·б ю·ű (5 pairs × 14.2%) -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <!-- я·ч: left=*(я) right="(ч) -->
    <Key latin:keySpec="&#x044F;" latin:keySecondarySpec="&#x0447;"
        latin:moreKeys="!text/morekeys_cyrillic_ya"
        latin:keyHintLabel="&quot;"
        latin:keyHintLabelLeft="*"
        latin:additionalMoreKeys="*,&quot;" />
    <!-- с·м: left='(с) right=:(м) -->
    <Key latin:keySpec="&#x0441;" latin:keySecondarySpec="&#x043C;"
        latin:keyHintLabel=":"
        latin:keyHintLabelLeft="'"
        latin:additionalMoreKeys="',:" />
    <!-- [row3_5]·т: left=;([row3_5]) right=!(т) -->
    <Key latin:keySpec="!text/keyspec_east_slavic_row3_5" latin:keySecondarySpec="&#x0442;"
        latin:moreKeys="!text/morekeys_cyrillic_i"
        latin:keyHintLabel="!"
        latin:keyHintLabelLeft=";"
        latin:additionalMoreKeys=";,!" />
    <!-- ь·б: left=?(ь) right=<(б) — 4th pair, not right-edge -->
    <Key latin:keySpec="&#x044C;" latin:keySecondarySpec="&#x0431;"
        latin:moreKeys="!text/morekeys_cyrillic_soft_sign"
        latin:keyHintLabel="&lt;"
        latin:keyHintLabelLeft="\?"
        latin:additionalMoreKeys="\?,&lt;" />
    <!-- ю·ű: left=>(ю), no right hint for ű (U+04AF) -->
    <Key latin:keySpec="&#x044E;" latin:keySecondarySpec="&#x04AF;"
        latin:moreKeys="!text/morekeys_cyrillic_yu"
        latin:keyHintLabelLeft="&gt;"
        latin:additionalMoreKeys="&gt;" />
</merge>
