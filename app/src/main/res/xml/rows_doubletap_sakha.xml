<?xml version="1.0" encoding="utf-8"?>
<!-- Double-tap Sakha rows: row1=6pairs+solo, row2=6pairs+solo, row3=5pairs -->
<merge xmlns:latin="http://schemas.android.com/apk/res-auto">
    <Row latin:keyWidth="14.286%p">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_sakha1" />
    </Row>
    <Row latin:keyWidth="14.286%p">
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_sakha2" />
    </Row>
    <Row latin:keyWidth="14.2%p">
        <Key latin:keyStyle="shiftKeyStyle" latin:keyWidth="10.8%p" />
        <include latin:keyboardLayout="@xml/rowkeys_doubletap_sakha3" />
        <Key latin:keyStyle="deleteKeyStyle" latin:keyWidth="fillRight" />
    </Row>
    <include latin:keyboardLayout="@xml/row_doubletap_qwerty4" />
</merge>
